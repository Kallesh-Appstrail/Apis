PORT=3000

# --- AWS S3 (from console) ---
# Region: S3 bucket → Properties → "AWS Region" (e.g. ap-south-1, us-east-1).
AWS_REGION=us-east-1
# Bucket name only (not ARN), from S3 → Buckets list.
S3_BUCKET=your-bucket-name

# IAM access keys for this API (recommended: dedicated IAM user, least privilege).
# AWS Console → IAM → Users → your user → Security credentials → Create access key
# → "Application running outside AWS" (or CLI). Copy Access key ID and Secret.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Only if you use temporary creds (STS/assumed role); leave empty for long-lived keys.
# AWS_SESSION_TOKEN=

# If you omit AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY, the SDK uses the default
# credential chain instead: environment on CI, ~/.aws/credentials, or EC2/Lambda role.

# Optional: if your bucket/objects are public, set base URL for stable links (no expiry)
# Example: https://your-bucket.s3.us-east-1.amazonaws.com
# S3_PUBLIC_BASE_URL=

# Presigned GET URL lifetime in seconds (default 3600). Ignored when S3_PUBLIC_BASE_URL is set.
PRESIGNED_GET_EXPIRES=3600

# Max upload size in bytes (default 500MB)
MAX_UPLOAD_BYTES=524288000

# --- AWS MediaConvert & CloudFront ---
# The endpoint for MediaConvert (e.g. https://abcd.mediaconvert.us-east-1.amazonaws.com)
MEDIACONVERT_ENDPOINT=
# The IAM Role ARN for MediaConvert to access S3
MEDIACONVERT_ROLE_ARN=
# The CloudFront Domain without https:// (e.g. dh8vby4alcwq5.cloudfront.net)
CLOUDFRONT_DOMAIN=
